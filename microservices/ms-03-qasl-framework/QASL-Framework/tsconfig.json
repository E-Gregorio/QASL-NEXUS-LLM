{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": [
    "e2e/**/*.ts",
    "unit/**/*.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "reports"
  ]
}
