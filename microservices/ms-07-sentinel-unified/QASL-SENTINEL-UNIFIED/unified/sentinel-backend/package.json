{
  "name": "qasl-sentinel-backend-unified",
  "version": "2.0.0",
  "description": "QASL API Sentinel Unified - Backend API Monitoring",
  "type": "module",
  "main": "src/index.mjs",
  "bin": {
    "sentinel": "./cli/sentinel-cli.mjs"
  },
  "scripts": {
    "monitor": "node cli/sentinel-cli.mjs start --watch",
    "start": "node cli/sentinel-cli.mjs start --watch",
    "check": "node cli/sentinel-cli.mjs check",
    "status": "node cli/sentinel-cli.mjs status",
    "import:swagger": "node cli/sentinel-cli.mjs import --swagger",
    "import:postman": "node cli/sentinel-cli.mjs import --postman",
    "import:har": "node cli/sentinel-cli.mjs import --har",
    "report": "node cli/sentinel-cli.mjs report",
    "report:email": "node cli/sentinel-cli.mjs email --send-report",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": ["api", "monitoring", "sentinel", "unified", "prometheus"],
  "author": "QASL Team - Quality Assurance Software Lab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "canvas": "^3.2.0",
    "chalk": "^5.6.2",
    "chartjs-node-canvas": "^5.0.0",
    "commander": "^12.1.0",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "nodemailer": "^6.9.15",
    "ora": "^8.1.0",
    "pdfkit": "^0.17.2",
    "simple-statistics": "^7.8.8",
    "socket.io": "^4.8.0",
    "swagger-parser": "^10.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
