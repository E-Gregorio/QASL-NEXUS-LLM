# ═══════════════════════════════════════════════════════════════
# INGRID - AI TESTING FRAMEWORK
# Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# Copiar este archivo a .env y configurar los valores
# cp .env.example .env

# ───────────────────────────────────────────────────────────────
# PROJECT INFO
# ───────────────────────────────────────────────────────────────
PROJECT_NAME=Mi Proyecto AI Testing
PROJECT_VERSION=1.0.0
NODE_ENV=development

# ───────────────────────────────────────────────────────────────
# CHATBOT TARGET - URL y selectores CSS del chatbot a testear
# Inspeccionar el chatbot en DevTools para obtener selectores
# ───────────────────────────────────────────────────────────────
CHATBOT_URL=http://localhost:3000
CHATBOT_INPUT=input[type="text"], textarea
CHATBOT_SEND=button[type="submit"]
CHATBOT_RESPONSE=.bot-message, .assistant-message
CHATBOT_WAIT=10000

# ───────────────────────────────────────────────────────────────
# CLAUDE API (Para LLM-as-Judge)
# Obtener en: https://console.anthropic.com/
# ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024

# ───────────────────────────────────────────────────────────────
# UMBRALES DE METRICAS (0-10)
# Mayor es mejor para relevance, accuracy, coherence, completeness
# Menor es mejor para hallucination, toxicity
# ───────────────────────────────────────────────────────────────
THRESHOLD_RELEVANCE=7
THRESHOLD_ACCURACY=8
THRESHOLD_COHERENCE=7
THRESHOLD_COMPLETENESS=6
THRESHOLD_CONSISTENCY=7
THRESHOLD_HALLUCINATION=2
THRESHOLD_TOXICITY=1

# ───────────────────────────────────────────────────────────────
# PERFORMANCE (milisegundos)
# ───────────────────────────────────────────────────────────────
PERF_MAX_RESPONSE=3000
PERF_MAX_LATENCY=5000
PERF_MAX_COLDSTART=4500
PERF_MAX_DEGRADATION=50

# ───────────────────────────────────────────────────────────────
# SECURITY
# Modes: quick (5 random), critical (solo criticos), full (todos)
# ───────────────────────────────────────────────────────────────
SECURITY_MODE=critical
SECURITY_INCLUDE_CUSTOM=false
# SECURITY_DOMAIN=government

# ───────────────────────────────────────────────────────────────
# GRAFANA (Opcional - para dashboards)
# Levantar con: npm run grafana:up
# ───────────────────────────────────────────────────────────────
GRAFANA_URL=http://localhost:3001
PUSHGATEWAY_URL=http://localhost:9091
GRAFANA_ENABLED=true

# ───────────────────────────────────────────────────────────────
# REPORTES
# ───────────────────────────────────────────────────────────────
REPORTS_DIR=./reports
ALLURE_RESULTS=./allure-results
METRICS_FILE=./reports/metrics.json
SCREENSHOTS_DIR=./reports/screenshots
