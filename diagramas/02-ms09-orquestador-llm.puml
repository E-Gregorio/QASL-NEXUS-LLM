@startuml MS09_Orquestador_LLM

!define DARKSLATE #0f172a
!define DARKBLUE #1a1a2e
!define PURPLE #6366f1
!define WHITE #f8fafc
!define SLATE #94a3b8

skinparam backgroundColor DARKSLATE
skinparam defaultFontColor WHITE
skinparam defaultFontSize 11
skinparam defaultFontName "Segoe UI"
skinparam shadowing true

skinparam rectangle {
    RoundCorner 15
    FontColor WHITE
    BorderThickness 2
}

skinparam arrow {
    Color SLATE
    Thickness 2
}

skinparam package {
    BackgroundColor DARKBLUE
    BorderColor PURPLE
    FontColor WHITE
    FontStyle bold
    BorderThickness 2
}

title <size:20><b>MS-09 ORQUESTADOR LLM</b></size>\n<size:13><color:SLATE>Cerebro del Sistema - Decision Engine + Multi-LLM (Opus/Sonnet/Gemini)</color></size>

' === CLIENTES ===
rectangle "**MS-02**\nPruebas Estaticas" as C1 #16213e;line:475569
rectangle "**MS-05**\nINGRID AI" as C2 #16213e;line:475569
rectangle "**MS-08**\nCI/CD Pipeline" as C3 #16213e;line:475569
rectangle "**MS-10**\nMCP Interfaz" as C4 #16213e;line:475569

package "MS-09 ORQUESTADOR LLM :8000" as CORE #0d1117 {

    rectangle "**API Gateway**\n<size:9>REST/JSON\nAuth + Rate Limit</size>" as API #1e293b;line:6366f1

    rectangle "**Decision Engine**\n<size:9>Reglas por tipo de tarea\nSelecciona LLM optimo</size>" as DE #1e1b4b;line:818cf8

    rectangle "**Prompt Builder**\n<size:9>Context Window\nSystem Prompts\nTemplates por tarea</size>" as PB #1e1b4b;line:818cf8

    package "OPUS 4.6 - Tareas Criticas" as TIER_OPUS #1a0a2e {
        rectangle "**Gap Analysis**\n<size:9><color:#a78bfa>claude-opus-4-6\nRazonamiento profundo\nDetecta gaps invisibles</color></size>" as OP1 #312e81;line:7c3aed
        rectangle "**VCR Calculation**\n<size:9><color:#a78bfa>claude-opus-4-6\nEvaluacion riesgo/valor\nDecision AUTO vs MANUAL</color></size>" as OP2 #312e81;line:7c3aed
        rectangle "**Test Generation**\n<size:9><color:#a78bfa>claude-opus-4-6\nCobertura exhaustiva\nEdge cases criticos</color></size>" as OP3 #312e81;line:7c3aed
    }

    package "SONNET 4.5 - Tareas Estructuradas" as TIER_SONNET #0a1628 {
        rectangle "**Bug Description**\n<size:9><color:#60a5fa>claude-sonnet-4-5\nRedaccion tecnica</color></size>" as SN1 #1e3a5f;line:3b82f6
        rectangle "**Template Fill**\n<size:9><color:#60a5fa>claude-sonnet-4-5\nLlenado mecanico</color></size>" as SN2 #1e3a5f;line:3b82f6
        rectangle "**Test Data Gen**\n<size:9><color:#60a5fa>claude-sonnet-4-5\nDatos variados</color></size>" as SN3 #1e3a5f;line:3b82f6
        rectangle "**Field Mapping**\n<size:9><color:#60a5fa>claude-sonnet-4-5\nMapeo entre sistemas</color></size>" as SN4 #1e3a5f;line:3b82f6
    }

    package "GEMINI 2.5 Pro - Vision" as TIER_GEMINI #0a2818 {
        rectangle "**Screenshot Analysis**\n<size:9><color:#38bdf8>gemini-2.5-pro\nVision multimodal\nUI/UX Review</color></size>" as GE #0c4a6e;line:0284c7
    }

    rectangle "**Response Validator**\n<size:9>Schema Validation\nQuality Check\nJSON Parse</size>" as VAL #1e293b;line:6366f1

    rectangle "**VCR Calculator**\n<size:9>Value (1-3) + Cost (1-3)\nRisk = Prob x Impact\nTotal >= 9: AUTO</size>" as VCR #713f12;line:fbbf24

    rectangle "**Template Filler**\n<size:9>Bug Report Generator\nISTQB Format\nJSON Output</size>" as TF #1e293b;line:6366f1

    rectangle "**Audit Log**\n<size:9>Model + Prompt + Response\nTokens + Duration\nTrazabilidad IA</size>" as AUDIT #1e293b;line:475569
}

database "**MS-12**\nPostgreSQL" as DB #0c4a6e;line:38bdf8

